rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidMission(data) {
      return data.keys().hasAll(['id', 'title']) &&
             data.id is string &&
             data.title is string &&
             (data.keys().hasAny(['points', 'reward_points', 'rewardPoints']));
    }

    function isValidVoucher(data) {
      return data.keys().hasAll(['id', 'title', 'code']) &&
             data.id is string &&
             data.title is string &&
             data.code is string &&
             (data.keys().hasAny(['cost', 'cost_points', 'points_cost']));
    }

    function isValidGame(data) {
      return data.keys().hasAll(['id', 'type']) &&
             data.id is string &&
             data.type is string;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /missions/{missionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidMission(incoming());
      allow delete: if isSignedIn();
    }

    match /vouchers/{voucherId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidVoucher(incoming());
      allow delete: if isSignedIn();
    }

    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidGame(incoming());
      allow delete: if isSignedIn();
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /point_histories/{historyId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /user_missions/{userMissionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /game_plays/{playId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
